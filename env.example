# ─────────────────────────────────────────────────────────────
#  Variables de entorno — RAÍZ (referencia). Copiar a .env.
#  Cada paquete tiene su propio env.example con el subconjunto que usa.
# ─────────────────────────────────────────────────────────────

# ── Supabase ──
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
# service_role: SOLO backend. Nunca exponer al frontend.
SUPABASE_SERVICE_ROLE_KEY=eyJ...
# anon: si el frontend habla directo con Supabase (no requerido en Fase 1).
SUPABASE_ANON_KEY=eyJ...
# Bucket de Storage para comprobantes.
SUPABASE_STORAGE_BUCKET=comprobantes

# ── Telegram ──
# Token del bot (BotFather). Ver README.
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
# chat_id de Diego (admin principal) y de la administradora/fiducia.
TELEGRAM_CHAT_ID_DIEGO=111111111
TELEGRAM_CHAT_ID_ADMIN=222222222
# Secreto que Telegram debe enviar en el header del webhook (X-Telegram-Bot-Api-Secret-Token).
TELEGRAM_WEBHOOK_SECRET=cambia-esto-largo-aleatorio

# ── Job diario protegido ──
# Header secreto requerido por POST /jobs/daily-check.
DAILY_CHECK_SECRET=cambia-esto-largo-aleatorio

# ── Zona horaria del negocio ──
APP_TIMEZONE=America/Bogota

# ── Auth frontend (password compartido) ──
# PIN/password único para entrar al panel.
ADMIN_PASSWORD=cambia-esto
# Secreto para firmar la cookie de sesión.
SESSION_SECRET=cambia-esto-largo-aleatorio

# ── OCR (Fase 2) ──
# Proveedor activo: gemini (free, recomendado) | openai
OCR_PROVIDER=gemini
# Gemini: API key de https://aistudio.google.com/apikey (sin tarjeta).
OCR_API_KEY=AIza...
# Opcional. Default gemini: gemini-2.0-flash · openai: gpt-4o-mini
OCR_MODEL=gemini-2.5-flash

# ── URLs ──
# URL pública del backend (Render).
BACKEND_URL=https://arriendos-backend.onrender.com
# URL pública del frontend (Vercel).
FRONTEND_URL=https://arriendos.vercel.app
