# Frontend (Next.js). Copiar a .env.local

# Auth multi-usuario: el login lo maneja el backend (/auth/login) y el JWT se
# guarda en una cookie httpOnly 'token'. Ya NO se usan ADMIN_PASSWORD ni
# SESSION_SECRET (eran del password compartido anterior).

# URL del backend (Render) para los proxies server-side (api/backend, api/cron, api/login).
# SOLO servidor: el navegador nunca la ve.
BACKEND_URL=http://localhost:3001

# API key compartida con el backend. La inyecta el proxy api/backend en
# el header X-Api-Key. SOLO servidor (sin NEXT_PUBLIC_).
API_KEY=cambia-esto-largo-aleatorio

# Secreto del cron diario (proxy api/cron). SOLO servidor.
DAILY_CHECK_SECRET=cambia-esto-largo-aleatorio
