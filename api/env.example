# Backend (NestJS). Copiar a .env
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_STORAGE_BUCKET=comprobantes

TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
TELEGRAM_CHAT_ID_DIEGO=111111111
TELEGRAM_CHAT_ID_ADMIN=222222222
TELEGRAM_WEBHOOK_SECRET=cambia-esto-largo-aleatorio

DAILY_CHECK_SECRET=cambia-esto-largo-aleatorio

# API key compartida: header X-Api-Key que envía el proxy server-side del
# frontend (defensa en capas: "vengo del proxy confiable"). La autorización
# por usuario la da el JWT (abajo).
API_KEY=cambia-esto-largo-aleatorio

# Auth multi-usuario (Fase 1). Firma de los JWT de sesión.
JWT_SECRET=cambia-esto-largo-aleatorio-min-32-chars
# Vida del token (formato ms: 8h, 1d, 30m). Default 8h.
JWT_EXPIRES=8h

APP_TIMEZONE=America/Bogota

# CORS: origen del frontend
FRONTEND_URL=http://localhost:3000

# OCR (Fase 2). Proveedor: gemini (free, recomendado) | openai
OCR_PROVIDER=gemini
# Gemini: API key de https://aistudio.google.com/apikey (sin tarjeta).
# OpenAI: sk-...
OCR_API_KEY=AIza...
# Opcional. Default gemini: gemini-2.0-flash · openai: gpt-4o-mini
OCR_MODEL=gemini-2.5-flash

PORT=3001
